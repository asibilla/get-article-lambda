{
  "name": "get-article-lambda",
  "packageManager": "yarn@4.10.3",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "scripts": {
    "build": "sam build",
    "invoke:local": "sam local invoke GetArticle -e ./mocks/event.json --env-vars ./mocks/env.json",
    "invoke:local:authorizer": "sam local invoke AuthorizerFunction -e ./mocks/authorizerEvent.json --env-vars ./mocks/env.json",
    "generate:mock": "sam local generate-event apigateway aws-proxy --method GET --path /get-article > ./mocks/event.json"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1048.0",
    "@aws-sdk/lib-dynamodb": "^3.1048.0"
  }
}
