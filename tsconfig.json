{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "moduleResolution": "bundler",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true, 
      "forceConsistentCasingInFileNames": true,
      "types": ["node"]
    },
    "exclude": ["node_modules"]
  }
